#include<iostream>
using namespace std;
int main() {
    char op;
    double num1, num2;
    cout << "enter the operators (+ , - , * , / ): ";
    cin >> op;
    cout << "enter the two numbers: ";
    cin >> num1 >> num2;

    switch(op) { 
        case '+' :
        cout << num1 << "+" << num2 << "=" << num1 + num2 ;
        break;
        case '-' :
        cout << num1 << "-" << num2 << "=" << num1 - num2 ;
        break;
        case '*' :
        cout << num1 << "*" << num2 << "=" << num1 * num2 ;
        break;
        case '/' :
        if (num2 !=0){
        cout << num1 << "/" << num2 << "=" << num1 / num2 ;
        }
        else
        cout << "Error! Dividing by zero";
        break; 
        
        default:
        cout << "Error! operator is not correct";
        break;
    
    }

    return 0;

}
